# ─── Server Environment Variables ───

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/securevault


# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_this
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_change_this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File Upload Limits (bytes)
# 5242880 bytes = 5MB 
# For larger files: 10485760 = 10MB, 20971520 = 20MB
MAX_FILE_SIZE=20971520

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Cloudinary (optional — leave empty to use local storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
